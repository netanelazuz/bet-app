# BET App - Environment template. Copy to .env and set values.
# The app loads .env automatically (config.py), so you don't need to set vars in the shell.
FLASK_APP=run
FLASK_ENV=development
SECRET_KEY=change-me-in-production
# Local dev (no PostgreSQL needed) – default:
DATABASE_URL=sqlite:///app.db
# PostgreSQL (uncomment and set user/password when using Postgres):
# DATABASE_URL=postgresql://user:password@localhost:5432/bet_db
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
